<?xml version="1.0" encoding="UTF-8"?>
<imixs-connect>

    <!-- Standard endpoint with all fields configured -->
    <endpoint id="SAP">
        <url>http://sap-api-server/imixs-hook</url>
        <apikey>test-secret-token</apikey>
        <timeout>5000</timeout>
    </endpoint>

    <!-- Endpoint without API key - typical for trusted internal services -->
    <endpoint id="INTERNAL">
        <url>http://internal-service/hook</url>
        <timeout>2000</timeout>
    </endpoint>

    <!-- Endpoint with environment variable placeholder -->
    <endpoint id="N8N">
        <url>https://n8n.my-company.com/webhook/imixs</url>
        <apikey>${env.N8N_API_KEY}</apikey>
    </endpoint>

</imixs-connect>
 